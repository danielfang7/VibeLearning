# Copy this file to .env.local and fill in your values

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Absolute path to the project you want to open when debugging the extension (F5)
# Example: /home/yourname/projects/my-app
# NOTE: VS Code reads this from your shell environment, not from .env.local.
# You must export it in your shell profile (~/.zshrc or ~/.bashrc):
#   export VIBELEARN_TEST_WORKSPACE=/path/to/your/project
# Then restart VS Code (or open it from the same terminal session).
VIBELEARN_TEST_WORKSPACE=
