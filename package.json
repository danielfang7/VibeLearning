{
  "name": "vibelearn",
  "displayName": "VibeLearn",
  "description": "Passive learning layer for AI-assisted development",
  "version": "0.0.1",
  "publisher": "vibelearn",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Education", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibelearn.quizNow",
        "title": "VibeLearning: Quiz Me Now"
      },
      {
        "command": "vibelearn.snooze",
        "title": "VibeLearning: Snooze (10 min)"
      },
      {
        "command": "vibelearn.explainCodebase",
        "title": "VibeLearning: Explain My Codebase"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibelearn",
          "title": "VibeLearn",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vibelearn": [
        {
          "type": "webview",
          "id": "vibelearn.panel",
          "name": "Learning"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vibelearn.quizNow",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "VibeLearn",
      "properties": {
        "vibelearn.promptTriggerCount": {
          "type": "number",
          "default": 10,
          "description": "Number of AI prompts before a learning intervention is triggered."
        },
        "vibelearn.sessionGapMinutes": {
          "type": "number",
          "default": 10,
          "description": "Minutes of inactivity before a session-gap intervention is triggered."
        },
        "vibelearn.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Anthropic API key. Required for generating interventions."
        },
        "vibelearn.enabledInterventionTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "concept_check",
              "explain_it_back",
              "micro_reading",
              "spot_the_bug",
              "refactor_challenge",
              "analogy_prompt"
            ]
          },
          "default": [
            "concept_check",
            "explain_it_back",
            "micro_reading",
            "spot_the_bug",
            "refactor_challenge",
            "analogy_prompt"
          ],
          "description": "Which quiz types VibeLearn can generate. Remove a type to disable it."
        },
        "vibelearn.minDifficulty": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 5,
          "description": "Minimum difficulty score (1–5) for quiz interventions. Increase to skip easy questions."
        },
        "vibelearn.maxDifficulty": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum difficulty score (1–5) for quiz interventions. Decrease to avoid hard questions."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "dev:seed": "node scripts/seed-session.mjs",
    "dev:seed:debrief": "node scripts/seed-session.mjs -- --mode=debrief",
    "dev:engine": "node scripts/run-engine.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
